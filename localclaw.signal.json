{
  "app": {
    "root": "./.localclaw"
  },
  "agents": {
    "defaults": {
      "workspace": "."
    }
  },
  "cron": {
    "enabled": true
  },
  "session": {
    "store": "agents/{agentId}/sessions/sessions.json"
  },
  "channels": {
    "enabled": ["signal"],
    "signal": {
      "cli_path": "signal-cli",
      "account": "+17143026547",
      "default_recipient": "",
      "timeout_seconds": 10
    }
  }
}
